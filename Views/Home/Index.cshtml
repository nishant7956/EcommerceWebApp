@model IEnumerable<QAAutomationPortfolio.Models.Product>

@{
    ViewData["Title"] = "Shop";
    var products = Model.ToList();
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" role="alert" style="border-radius: 0; margin-bottom: 0;">
        <div class="container d-flex align-items-center gap-3">
            <i class="bi bi-check-circle-fill text-success fs-5"></i>
            <span>@TempData["SuccessMessage"]</span>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <div class="hero-content">
                    <div class="hero-badge">
                        <i class="bi bi-stars"></i> New Season 2026
                    </div>
                    <h1 class="hero-title">
                        Discover <span class="accent">Premium</span><br>Products
                    </h1>
                    <p class="hero-subtitle">
                        Shop our curated collection of the finest products, delivered straight to your door with unmatched quality and style.
                    </p>
                    <div class="hero-cta">
                        <a href="#products" class="btn btn-hero-primary">
                            Shop Now <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                        <a href="#categories" class="btn btn-hero-secondary">
                            Browse Categories
                        </a>
                    </div>
                    <div class="hero-stats">
                        <div>
                            <div class="hero-stat-value">@products.Count+</div>
                            <div class="hero-stat-label">Products</div>
                        </div>
                        <div>
                            <div class="hero-stat-value">10k+</div>
                            <div class="hero-stat-label">Customers</div>
                        </div>
                        <div>
                            <div class="hero-stat-value">4.9★</div>
                            <div class="hero-stat-label">Rating</div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 d-none d-lg-block">
                <div class="hero-image-card">
                    <div class="floating-badge top-left">
                        <i class="bi bi-truck text-success"></i> Free Delivery
                    </div>
                    <div class="hero-product-placeholder">
                        <i class="bi bi-bag-heart"></i>
                    </div>
                    <p class="text-white fw-semibold mb-1">Featured Collection</p>
                    <p class="text-secondary small mb-0">New arrivals every week</p>
                    <div class="floating-badge bottom-right">
                        <i class="bi bi-shield-check text-primary"></i> Secure Checkout
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Bar -->
<section class="features-bar">
    <div class="container">
        <div class="row g-3 justify-content-center">
            <div class="col-6 col-md-3">
                <div class="feature-item">
                    <div class="feature-icon"><i class="bi bi-truck"></i></div>
                    <div>
                        <div class="fw-semibold" style="font-size:14px;">Free Shipping</div>
                        <div class="text-muted" style="font-size:12px;">On orders over $50</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="feature-item">
                    <div class="feature-icon"><i class="bi bi-arrow-counterclockwise"></i></div>
                    <div>
                        <div class="fw-semibold" style="font-size:14px;">Easy Returns</div>
                        <div class="text-muted" style="font-size:12px;">30-day return policy</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="feature-item">
                    <div class="feature-icon"><i class="bi bi-shield-check"></i></div>
                    <div>
                        <div class="fw-semibold" style="font-size:14px;">Secure Payment</div>
                        <div class="text-muted" style="font-size:12px;">256-bit SSL encrypted</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="feature-item">
                    <div class="feature-icon"><i class="bi bi-headset"></i></div>
                    <div>
                        <div class="fw-semibold" style="font-size:14px;">24/7 Support</div>
                        <div class="text-muted" style="font-size:12px;">Always here for you</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Categories -->
<section id="categories" class="py-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4">
            <div>
                <h2 class="section-title mb-1">Shop by Category</h2>
                <p class="section-subtitle mb-0">Find exactly what you're looking for</p>
            </div>
        </div>
        <div class="row g-3">
            <div class="col-6 col-md-3">
                <div class="category-card" style="background: linear-gradient(135deg, #667eea, #764ba2);">
                    <div class="category-card-overlay"></div>
                    <div class="category-card-content">
                        <div class="category-name">Electronics</div>
                        <div class="category-count">240+ Products</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="category-card" style="background: linear-gradient(135deg, #f093fb, #f5576c);">
                    <div class="category-card-overlay"></div>
                    <div class="category-card-content">
                        <div class="category-name">Fashion</div>
                        <div class="category-count">180+ Products</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="category-card" style="background: linear-gradient(135deg, #4facfe, #00f2fe);">
                    <div class="category-card-overlay"></div>
                    <div class="category-card-content">
                        <div class="category-name">Home & Garden</div>
                        <div class="category-count">320+ Products</div>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="category-card" style="background: linear-gradient(135deg, #43e97b, #38f9d7);">
                    <div class="category-card-overlay"></div>
                    <div class="category-card-content">
                        <div class="category-name">Sports</div>
                        <div class="category-count">150+ Products</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Products Grid -->
<section id="products" class="pb-5">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-4 flex-wrap gap-3">
            <div>
                <h2 class="section-title mb-1">Featured Products</h2>
                <p class="section-subtitle mb-0">@products.Count products available</p>
            </div>
            <div class="d-flex gap-2">
                <select class="form-select form-select-sm" style="width: auto; border-radius: 8px;">
                    <option>Sort: Featured</option>
                    <option>Price: Low to High</option>
                    <option>Price: High to Low</option>
                    <option>Newest First</option>
                </select>
            </div>
        </div>

        @if (!products.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-box-seam display-1 text-muted opacity-25"></i>
                <h4 class="mt-4 text-muted">No products yet</h4>
                <p class="text-muted">Go to the Admin Portal to add your first product.</p>
                <a asp-controller="Products" asp-action="Create" class="btn btn-primary mt-2">Add Product</a>
            </div>
        }
        else
        {
            <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-4">
                @{ int i = 0; }
                @foreach (var item in products)
                {
                    <div class="col">
                        <div class="product-card h-100">
                            <div class="product-card-img-wrap">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Name" />
                                }
                                else
                                {
                                    <div class="product-placeholder">
                                        <i class="bi bi-image"></i>
                                        <span style="font-size: 12px;">No Image</span>
                                    </div>
                                }
                                @if (i % 3 == 0) { <span class="product-badge badge-new">New</span> }
                                @if (i % 5 == 1) { <span class="product-badge badge-sale">Sale</span> }
                                <button class="product-wishlist-btn" type="button" title="Add to Wishlist">
                                    <i class="bi bi-heart"></i>
                                </button>
                            </div>
                            <div class="product-card-body">
                                <div class="product-category">Accessories</div>
                                <div class="product-name">@item.Name</div>
                                <div class="product-rating">
                                    <i class="bi bi-star-fill star"></i>
                                    <i class="bi bi-star-fill star"></i>
                                    <i class="bi bi-star-fill star"></i>
                                    <i class="bi bi-star-fill star"></i>
                                    <i class="bi bi-star-half star"></i>
                                    <span class="rating-count">(42)</span>
                                </div>
                                <div class="product-price-row">
                                    <div>
                                        <span class="product-price">$@item.Price.ToString("0.00")</span>
                                        @if (i % 4 == 0) { <span class="product-price-original">$@((item.Price * 1.2m).ToString("0.00"))</span> }
                                    </div>
                                    <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn-add-cart" @(item.StockQuantity <= 0 ? "disabled" : "") title="Add to Cart">
                                            <i class="bi bi-cart-plus"></i>
                                        </button>
                                    </form>
                                </div>
                                @if (item.StockQuantity > 0)
                                {
                                    <div class="stock-in mt-2">In Stock</div>
                                }
                                else
                                {
                                    <div class="stock-out mt-2">Out of Stock</div>
                                }
                            </div>
                        </div>
                    </div>
                    @{ i++; }
                }
            </div>
        }
    </div>
</section>
