@model QAAutomationPortfolio.Models.Product

@{
    ViewData["Title"] = "Add Product";
}

<div class="admin-page">
    <div class="container" style="max-width: 680px;">
        <!-- Breadcrumb -->
        <div class="d-flex align-items-center gap-2 mb-3">
            <a asp-controller="Home" asp-action="Index" class="text-muted small text-decoration-none"><i class="bi bi-house"></i></a>
            <i class="bi bi-chevron-right text-muted" style="font-size:11px;"></i>
            <a asp-action="Index" class="text-muted small text-decoration-none">Admin</a>
            <i class="bi bi-chevron-right text-muted" style="font-size:11px;"></i>
            <span class="small text-muted">Add Product</span>
        </div>

        <h1 class="fw-bold mb-4" style="font-size: 1.6rem; letter-spacing: -0.5px;">
            <i class="bi bi-plus-circle text-accent me-2"></i>Add New Product
        </h1>

        <div class="form-card">
            <form asp-action="Create" id="create-product-form">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small"></div>

                <div class="mb-4">
                    <label asp-for="Name" class="form-label">Product Name</label>
                    <input asp-for="Name" class="form-control" id="product-name" placeholder="e.g. Premium Wireless Headphones" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" id="product-description" rows="3" placeholder="Describe your product..."></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label asp-for="Price" class="form-label">Price (USD)</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Price" class="form-control" id="product-price" type="number" step="0.01" min="0" placeholder="0.00" />
                        </div>
                        <span asp-validation-for="Price" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="StockQuantity" class="form-label">Stock Quantity</label>
                        <input asp-for="StockQuantity" class="form-control" id="product-stock" type="number" min="0" placeholder="0" />
                        <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="ImageUrl" class="form-label">Image URL <span class="text-muted fw-normal">(optional)</span></label>
                    <input asp-for="ImageUrl" class="form-control" id="product-imageurl" placeholder="https://example.com/image.jpg" />
                    <div class="form-text">Provide a direct link to a product image. Leave blank to use a placeholder.</div>
                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center pt-2">
                    <a asp-action="Index" class="btn btn-outline-secondary" style="border-radius:10px;">
                        <i class="bi bi-arrow-left me-1"></i> Back
                    </a>
                    <button type="submit" class="btn btn-primary px-5" id="btn-submit-product">
                        <i class="bi bi-check-lg me-1"></i> Create Product
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
